#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-commit] cargo fmt --all --check"
cargo fmt --all --check

echo "[pre-commit] cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "[pre-commit] cargo test --workspace"
cargo test --workspace

echo "[pre-commit] cargo test --doc -p stim"
cargo test --doc -p stim

echo "[pre-commit] python -m unittest tools.tests.test_stim_rust_parity_audit tools.tests.test_stim_api_inventory"
python -m unittest tools.tests.test_stim_rust_parity_audit tools.tests.test_stim_api_inventory
